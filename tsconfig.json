{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",

    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    
    "strict": true,
    "noEmit": true,
    "composite": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "forceConsistentCasingInFileNames": true,

    "types": [
      "bun-types"
    ]
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}
