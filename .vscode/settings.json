{
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  
  "eslint.validate": [
    "typescript",
    "javascript"
  ],

  "cSpell.language": "en,fr",

  "markdownlint.config": {
    "MD024": {
      "siblings_only": true
    }
  }
}